# Copy to .env and edit. Every value here matches the Settings default
# in src/tairos_api/config.py, so an empty .env is equivalent to this
# file — it's here as a reference for what CAN be set.

# ── App ──────────────────────────────────────────────────────
ENV=dev
DEBUG=true

# ── Database ─────────────────────────────────────────────────
# Default puts the DB at apps/api/.data/tairos.sqlite. Change to
# point at a shared dev DB or a test scratch file if you need to.
# DATABASE_URL=sqlite:///./.data/tairos.sqlite

# Optional. Path to the SpatiaLite extension module.
# SPATIALITE_PATH=C:/tools/spatialite/mod_spatialite.dll

# ── HTTP ─────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000

# Comma-separated. Empty disables CORS middleware entirely.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
