# Copy to .env.local (git-ignored via the root .gitignore) and edit.
# Every value here matches the hard-coded default in src/lib/apiClient.js
# and related modules — an empty .env.local behaves identically to this
# file and is the intended dev setup.

# Base URL of the FastAPI backend (apps/api). Leave unset in a
# reverse-proxy deployment where frontend and backend share an origin;
# the apiClient then targets same-origin /v1/... paths.
VITE_API_URL=http://localhost:8000
