{
  "name": "tairos",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Tairos Sentinel — multi-domain command console for tactical planning, persistent situational monitoring, and coordinated defensive + offensive operations. Monorepo root: web frontend, FastAPI backend, shared packages.",
  "keywords": [
    "uav",
    "drone",
    "coverage-planning",
    "geospatial",
    "situational-awareness",
    "leaflet",
    "tairos",
    "monorepo"
  ],
  "author": "Tairos",
  "license": "UNLICENSED",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@tairos/web",
    "build": "npm run build --workspace=@tairos/web",
    "preview": "npm run preview --workspace=@tairos/web",
    "start": "npm run start --workspace=@tairos/web",
    "assistant": "node scripts/assistant-server.mjs",
    "seed:global-sites": "node scripts/seed-global-sites.mjs",
    "seed:conflict-assets": "node scripts/seed-conflict-assets.mjs",
    "seed:forces": "node scripts/seed-forces.mjs",
    "verify:global-sites": "node -e \"import('node:fs').then(m=>{const d=JSON.parse(m.readFileSync('apps/web/src/data/globalSites.json','utf8'));const by=k=>d.reduce((a,s)=>(a[s[k]]=(a[s[k]]||0)+1,a),{});console.log('total',d.length);console.log('operator',by('operator'));console.log('region',by('region'));console.log('type',by('type'));const ids=new Set(d.map(s=>s.id));console.log('unique_ids',ids.size);})\""
  },
  "devDependencies": {
    "pdf-parse": "^2.4.5"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=8"
  }
}
